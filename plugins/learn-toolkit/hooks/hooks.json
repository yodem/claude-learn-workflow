{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/validate-output.sh",
            "statusMessage": "Validating learn-toolkit output structure..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/verify-artifacts.sh",
            "statusMessage": "Verifying learn-toolkit artifacts were generated..."
          }
        ]
      }
    ]
  }
}
